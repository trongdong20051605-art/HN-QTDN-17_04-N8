<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_chuc_vu_tree" model="ir.ui.view">
            <field name="name">chuc_vu.tree</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <tree string="Danh sách chức vụ">
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="cap_bac"/>
                    <field name="muc_luong_de_xuat"/>
                    <field name="phu_cap_chuc_vu"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record id="view_chuc_vu_form" model="ir.ui.view">
            <field name="name">chuc_vu.form</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <form string="Chức vụ">
                    <sheet>
                        <group>
                            <group>
                                <field name="ma_chuc_vu"/>
                                <field name="ten_chuc_vu"/>
                                <field name="cap_bac"/>
                            </group>
                            <group>
                                <field name="muc_luong_de_xuat"/>
                                <field name="phu_cap_chuc_vu"/>
                                <field name="trang_thai"/>
                            </group>
                        </group>
                        <group>
                            <field name="mo_ta_cong_viec"/>
                        </group>
<notebook>
    <page string="Danh sách nhân viên">
        <field name="nhan_vien_ids">
            <tree>
                <field name="ma_dinh_danh"/>
                <field name="ho_dem"/>
                <field name="ten"/>
                <field name="phong_ban_id"/>
                <field name="ngay_vao_lam"/>
                <field name="trang_thai_lam_viec"/>
            </tree>
        </field>
    </page>
</notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_chuc_vu" model="ir.actions.act_window">
            <field name="name">Chức vụ</field>
            <field name="res_model">chuc_vu</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
